#!/bin/bash

# Simplified sketchybar config with TokyoNight theme + aerospace workspaces

source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/icons.sh"

PLUGIN_DIR="$CONFIG_DIR/plugins"
NERD_FONT="Symbols Nerd Font:Regular"

##### Bar Appearance #####
sketchybar --bar position=top height=42 \
                 color=$BAR_COLOR \
                 border_width=0 \
                 corner_radius=0 \
                 margin=0 \
                 blur_radius=0 \
                 padding_left=16 \
                 padding_right=16 \
                 shadow=off \
                 sticky=on \
                 topmost=window \
                 notch_width=200

##### Changing Defaults #####
default=(
  updates=when_shown
  icon.font="$NERD_FONT:15.0"
  icon.color=$ICON_COLOR
  icon.padding_left=6
  icon.padding_right=6
  label.font="SF Pro:Semibold:13.0"
  label.color=$LABEL_COLOR
  label.padding_left=6
  label.padding_right=6
  padding_left=8
  padding_right=8
  background.height=26
  background.corner_radius=6
  background.border_width=1
  background.border_color=$BACKGROUND_2
  popup.background.border_width=2
  popup.background.corner_radius=6
  popup.background.border_color=$POPUP_BORDER_COLOR
  popup.background.color=$POPUP_BACKGROUND_COLOR
)

sketchybar --default "${default[@]}"

##### Left Side — Aerospace Workspace Indicators #####

sketchybar --add event aerospace_workspace_change

# Build monitor ID mapping: aerospace monitor-id -> sketchybar display ID (NSScreen)
declare -A monitor_map
while IFS=" " read -r aero_id nsscreen_id; do
  monitor_map["$aero_id"]="$nsscreen_id"
done < <(aerospace list-monitors --format '%{monitor-id} %{monitor-appkit-nsscreen-screens-id}' 2>/dev/null)

# Create workspace items, assigning each to the correct display
for aero_monitor_id in $(echo "${!monitor_map[@]}" | tr ' ' '\n' | sort -n); do
  display_id="${monitor_map[$aero_monitor_id]}"
  for sid in $(aerospace list-workspaces --monitor "$aero_monitor_id" 2>/dev/null); do
    sketchybar --add item space.$sid left \
               --subscribe space.$sid aerospace_workspace_change \
               --set space.$sid \
                     display="$display_id" \
                     icon="$sid" \
                     icon.font="SF Pro:Bold:13.0" \
                     icon.color=$GREY \
                     icon.padding_left=10 \
                     icon.padding_right=10 \
                     label.drawing=off \
                     padding_left=2 \
                     padding_right=2 \
                     background.color=$BACKGROUND_1 \
                     background.corner_radius=6 \
                     background.height=26 \
                     background.drawing=on \
                     background.border_width=0 \
                     click_script="aerospace workspace $sid" \
                     script="$PLUGIN_DIR/aerospace.sh $sid"
  done
done

##### Right Side Items (rightmost first) #####

# Clock (rightmost)
sketchybar --add item clock right \
           --set clock icon="󰅐" \
                       icon.font="$NERD_FONT:15.0" \
                       icon.color=$YELLOW \
                       icon.padding_left=8 \
                       icon.padding_right=6 \
                       label.font="SF Pro:Medium:12.0" \
                       label.color=$WHITE \
                       label.padding_left=4 \
                       label.padding_right=8 \
                       update_freq=10 \
                       script="$PLUGIN_DIR/clock.sh" \
                       background.color=$BACKGROUND_1 \
                       background.drawing=on \
                       padding_left=4 \
                       padding_right=4

# Battery
sketchybar --add item battery right \
           --set battery icon.font="$NERD_FONT:15.0" \
                        icon.color=$ACCENT_SECONDARY \
                        icon.padding_left=8 \
                        icon.padding_right=6 \
                        label.font="SF Pro:Medium:12.0" \
                        label.color=$WHITE \
                        label.padding_left=4 \
                        label.padding_right=8 \
                        update_freq=120 \
                        script="$PLUGIN_DIR/battery.sh" \
                        background.color=$BACKGROUND_1 \
                        background.drawing=on \
                        padding_left=4 \
                        padding_right=4 \
           --subscribe battery system_woke power_source_change

# Volume
sketchybar --add item volume right \
           --set volume icon.font="$NERD_FONT:15.0" \
                        icon.color=$ACCENT_PRIMARY \
                        icon.padding_left=10 \
                        icon.padding_right=12 \
                        label.drawing=off \
                        script="$PLUGIN_DIR/volume.sh" \
                        background.color=$BACKGROUND_1 \
                        background.drawing=on \
                        padding_left=4 \
                        padding_right=4 \
                        click_script="$PLUGIN_DIR/volume_click.sh" \
                        popup.background.border_width=2 \
                        popup.background.corner_radius=6 \
                        popup.background.border_color=$POPUP_BORDER_COLOR \
                        popup.background.color=$POPUP_BACKGROUND_COLOR \
                        popup.horizontal=on \
           --subscribe volume volume_change

# Network (wifi/ethernet)
sketchybar --add item wifi right \
           --set wifi icon.font="$NERD_FONT:15.0" \
                      icon.padding_left=8 \
                      icon.padding_right=8 \
                      label.drawing=off \
                      update_freq=10 \
                      script="$PLUGIN_DIR/wifi.sh" \
                      background.color=$BACKGROUND_1 \
                      background.drawing=on \
                      padding_left=4 \
                      padding_right=4

# Mic
sketchybar --add item mic right \
           --subscribe mic mouse.exited.global \
           --set mic icon.font="$NERD_FONT:15.0" \
                     icon.padding_left=8 \
                     icon.padding_right=6 \
                     label.font="SF Pro:Medium:11.0" \
                     label.padding_left=4 \
                     label.padding_right=8 \
                     update_freq=5 \
                     script="$PLUGIN_DIR/mic.sh" \
                     click_script="$PLUGIN_DIR/mic_click.sh" \
                     background.color=$BACKGROUND_1 \
                     background.drawing=on \
                     padding_left=4 \
                     padding_right=4 \
                     popup.background.border_width=2 \
                     popup.background.corner_radius=6 \
                     popup.background.border_color=$POPUP_BORDER_COLOR \
                     popup.background.color=$POPUP_BACKGROUND_COLOR

# Calendar Events
sketchybar --add item calendar right \
           --subscribe calendar mouse.exited.global \
           --set calendar icon.font="$NERD_FONT:16.0" \
                          icon.padding_left=8 \
                          icon.padding_right=6 \
                          label.font="SF Pro:Medium:13.0" \
                          label.padding_left=4 \
                          label.padding_right=10 \
                          label.max_chars=40 \
                          update_freq=60 \
                          script="$PLUGIN_DIR/calendar.sh" \
                          click_script="$PLUGIN_DIR/calendar_click.sh" \
                          popup.background.border_width=2 \
                          popup.background.corner_radius=8 \
                          popup.background.border_color=$POPUP_BORDER_COLOR \
                          popup.background.color=$POPUP_BACKGROUND_COLOR \
                          background.color=$BACKGROUND_1 \
                          background.drawing=on \
                          background.height=26 \
                          padding_left=4 \
                          padding_right=4

# Now Playing (leftmost of right side)
sketchybar --add item now_playing right \
           --set now_playing icon.font="$NERD_FONT:15.0" \
                            icon.padding_left=8 \
                            icon.padding_right=6 \
                            label.font="SF Pro:Medium:12.0" \
                            label.padding_left=4 \
                            label.padding_right=8 \
                            update_freq=2 \
                            script="$PLUGIN_DIR/now_playing.sh" \
                            background.color=$BACKGROUND_1 \
                            background.drawing=on \
                            drawing=on \
                            padding_left=4 \
                            padding_right=4

##### Finalize Setup #####
sketchybar --update
