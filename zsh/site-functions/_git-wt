#compdef git-wt
#description personal worktree helper

_git_wt_branches() {
  local -a branches
  branches=("${(@f)$(git wt __complete-branches 2>/dev/null)}")
  compadd -a branches
}

_git_wt_remove_targets() {
  local -a targets
  local -a descriptions
  local line target description

  while IFS=$'\t' read -r target description; do
    [[ -z "$target" ]] && continue
    targets+=("$target")
    descriptions+=("$target:$description")
  done < <(git wt __complete-remove 2>/dev/null)

  if (( ${#descriptions[@]} )); then
    _describe -t worktrees 'worktree' descriptions
  else
    compadd -a targets
  fi
}

_git-wt() {
  local curcontext="$curcontext" state line
  local -a commands

  if [[ "${words[1]}" == git && "${words[2]}" == wt ]]; then
    words=(git-wt ${words[3,-1]})
    (( CURRENT -= 1 ))
  fi

  commands=(
    'add:create a worktree and run inferred setup'
    'remove:remove a worktree by branch, basename, or path'
    'rm:remove a worktree by branch, basename, or path'
    'list:list known worktrees'
    'ls:list known worktrees'
    'prune:prune stale worktree metadata'
    'help:show help'
  )

  _arguments -C \
    '1:command:->command' \
    '*::argument:->argument'

  case "$state" in
    command)
      _describe -t commands command commands
      ;;
    argument)
      case "${words[2]}" in
        add)
          _arguments -S \
            '--no-setup[skip inferred setup]' \
            '--no-copy[skip .worktreeinclude copy]' \
            '--no-mise[skip mise trust/install]' \
            '--no-install[skip package install]' \
            '--no-direnv[skip direnv allow]' \
            '1:branch:_git_wt_branches' \
            '2:base:_git_wt_branches' \
            '3:path:_directories'
          ;;
        remove | rm)
          _arguments -S \
            '(-f --force)'{-f,--force}'[force removal of dirty worktree]' \
            '1:worktree:_git_wt_remove_targets'
          ;;
        prune)
          _arguments -S \
            '(-n --dry-run)'{-n,--dry-run}'[show what would be pruned]' \
            '(-v --verbose)'{-v,--verbose}'[report pruned objects]' \
            '--expire=[expire objects older than time]:time'
          ;;
      esac
      ;;
  esac
}
